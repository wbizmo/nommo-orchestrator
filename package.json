{
  "name": "nommo-orchestrator",
  "version": "0.1.0",
  "description": "NOMMO is a TypeScript distributed systems control plane for service discovery, node health monitoring, failure detection, routing decisions, and self-healing orchestration experiments.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "author": "Williams Ashibuogwu (wbizmo)",
  "license": "Apache-2.0",
  "dependencies": {
    "@fastify/cors": "latest",
    "@fastify/helmet": "latest",
    "fastify": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@vitest/coverage-v8": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
